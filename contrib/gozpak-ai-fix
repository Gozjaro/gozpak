#!/bin/sh -ef
# Diagnose a package build failure using AI.
#
# Usage: gozpak ai-fix <name> [log-file]
#
# Reads the most recent build log (or a specified log file), the package's
# build script and depends, and asks an AI backend to diagnose the issue.

# shellcheck source=gozpak-ai-common
_dir=$(dirname "$(readlink -f "$0")")
. "$_dir/gozpak-ai-common"

die() { printf 'ERROR: %s\n' "$*" >&2; exit 1; }
log() { printf '\033[1;33m->\033[m %s\n' "$*" >&2; }

# --- argument parsing --------------------------------------------------------
[ "$#" -ge 1 ] || die "usage: gozpak ai-fix <name> [log-file]"

pkg_name=$1
log_file=${2:-}

# --- locate the build log ----------------------------------------------------
if [ -z "$log_file" ]; then
    cac_dir=${XDG_CACHE_HOME:-"$HOME/.cache"}/gozpak/logs
    # Find the most recent log for this package.
    log_file=$(find "$cac_dir" -name "${pkg_name}-*" -type f 2>/dev/null |
               sort -r | head -1)
    [ -n "$log_file" ] || die "no build log found for '$pkg_name' in $cac_dir"
fi

[ -f "$log_file" ] || die "log file not found: $log_file"
log "using build log: $log_file"

# --- locate the package recipe -----------------------------------------------
# Search GOZPAK_PATH for the package directory.
IFS=:
pkg_dir=""
for _path in ${GOZPAK_PATH:-}; do
    if [ -d "$_path/$pkg_name" ]; then
        pkg_dir="$_path/$pkg_name"
        break
    fi
done
unset IFS

# --- gather context ----------------------------------------------------------
# Last 150 lines of the build log (where the error usually is).
build_log=$(tail -150 "$log_file")

# Build script and depends.
build_script=""
depends=""
if [ -n "$pkg_dir" ]; then
    [ -f "$pkg_dir/build" ]   && build_script=$(cat "$pkg_dir/build")
    [ -f "$pkg_dir/depends" ] && depends=$(cat "$pkg_dir/depends")
    log "found recipe at $pkg_dir"
else
    log "recipe not found in GOZPAK_PATH, diagnosing from log only"
fi

# --- construct AI prompt -----------------------------------------------------
prompt="You are a Linux build engineer debugging a package build failure on Gozjaro Linux (LFS-based, musl or glibc, x86_64).

Package: $pkg_name

Build script:
\`\`\`sh
$build_script
\`\`\`

Dependencies:
$depends

Build log (last 150 lines):
\`\`\`
$build_log
\`\`\`

Diagnose the build failure:
1. What is the root cause of the error?
2. Is it a missing dependency, a configure flag issue, a patch needed, or something else?
3. Provide a concrete fix (modified build script, missing dependency to add, or patch to apply).

Be concise and actionable."

# --- query AI ----------------------------------------------------------------
log "querying $GOZPAK_AI_BACKEND for diagnosis"
response=$(ai_query "$prompt")

# --- output ------------------------------------------------------------------
printf '\n%s\n' "=== AI Diagnosis for $pkg_name ==="
printf '%s\n' "$response"
printf '%s\n' "=================================="
