#!/bin/sh -ef
# Check for upstream version updates using AI.
#
# Usage: gozpak ai-update <name>
#
# Reads the package's current version and sources, asks the AI to check
# if a newer version is available, and suggests updates.

# shellcheck source=gozpak-ai-common
_dir=$(dirname "$(readlink -f "$0")")
. "$_dir/gozpak-ai-common"

die() { printf 'ERROR: %s\n' "$*" >&2; exit 1; }
log() { printf '\033[1;33m->\033[m %s\n' "$*" >&2; }

# --- argument parsing --------------------------------------------------------
[ "$#" -ge 1 ] || die "usage: gozpak ai-update <name> [name2 ...]"

for pkg_name do

# --- locate the package recipe -----------------------------------------------
IFS=:
pkg_dir=""
for _path in ${GOZPAK_PATH:-}; do
    if [ -d "$_path/$pkg_name" ]; then
        pkg_dir="$_path/$pkg_name"
        break
    fi
done
unset IFS

[ -n "$pkg_dir" ] || { log "WARNING: '$pkg_name' not found in GOZPAK_PATH, skipping"; continue; }

# --- read current recipe -----------------------------------------------------
[ -f "$pkg_dir/version" ] || { log "WARNING: no version file for $pkg_name"; continue; }
read -r cur_ver cur_rel < "$pkg_dir/version"

sources=""
[ -f "$pkg_dir/sources" ] && sources=$(cat "$pkg_dir/sources")

log "$pkg_name: current version $cur_ver-$cur_rel"

# --- construct AI prompt -----------------------------------------------------
prompt="You are checking for upstream version updates for a Linux package.

Package: $pkg_name
Current version: $cur_ver
Current source URLs:
$sources

Based on your knowledge of this software project:
1. What is the latest stable release version?
2. If newer than $cur_ver, provide the updated source URL(s).
3. Are there any important changes or breaking changes to be aware of?

If you are not confident about the latest version, say so clearly.
Be concise: version number, URL, and any critical notes only."

# --- query AI ----------------------------------------------------------------
log "querying $GOZPAK_AI_BACKEND for version info"
response=$(ai_query "$prompt")

# --- output ------------------------------------------------------------------
printf '\n%s\n' "=== $pkg_name: version check ==="
printf '%s\n' "$response"
printf '%s\n' "================================="

done
