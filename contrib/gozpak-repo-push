#!/bin/sh -e
# Push repository tarballs and index to a remote mirror.
#
# Usage: gozpak repo-push [dir]
#
# Uploads the contents of the repo directory to the configured destination.
# Supports rsync, scp, and rclone.
#
# Configuration:
#   GOZPAK_REPO_PUSH_CMD  — push command (default: rsync)
#   GOZPAK_REPO_PUSH_DEST — remote destination (required)
#   GOZPAK_REPO_PUSH_OPTS — extra options for the push command

die() { printf 'ERROR: %s\n' "$*" >&2; exit 1; }
log() { printf '\033[1;33m->\033[m %s\n' "$*" >&2; }

repo_dir=${1:-${GOZPAK_REPO_OUT:-./repo}}
push_cmd=${GOZPAK_REPO_PUSH_CMD:-rsync}
push_dest=${GOZPAK_REPO_PUSH_DEST:-}
push_opts=${GOZPAK_REPO_PUSH_OPTS:-}

[ -d "$repo_dir" ] || die "directory not found: $repo_dir"
[ -f "$repo_dir/repo.index" ] || die "no repo.index in $repo_dir (run 'gozpak repo-index' first)"
[ -n "$push_dest" ] || die "GOZPAK_REPO_PUSH_DEST not set"

command -v "$push_cmd" >/dev/null 2>&1 ||
    die "$push_cmd not found (set GOZPAK_REPO_PUSH_CMD)"

_count=$(ls -1 "$repo_dir"/*.tar.* 2>/dev/null | wc -l | tr -d ' ')
log "pushing $_count package(s) + repo.index to $push_dest"

case $push_cmd in
    rsync)
        # shellcheck disable=2086
        rsync -avz --progress $push_opts "$repo_dir/" "$push_dest/"
        ;;
    scp)
        # shellcheck disable=2086
        scp $push_opts "$repo_dir"/repo.index "$repo_dir"/*.tar.* "$push_dest/"
        ;;
    rclone)
        # shellcheck disable=2086
        rclone copy $push_opts "$repo_dir/" "$push_dest/" --include "*.tar.*" --include "repo.index"
        ;;
    *)
        # Generic: just run the command with src and dest.
        # shellcheck disable=2086
        "$push_cmd" $push_opts "$repo_dir/" "$push_dest/"
        ;;
esac

log "push complete"
